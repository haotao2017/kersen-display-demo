# -----------------------------------------------
# Kersen Display — 环境变量说明
# 复制此文件为 .env 并填写真实值
# -----------------------------------------------

# Payload 加密密钥（必填，生产环境请用 32 位以上随机字符串）
PAYLOAD_SECRET=replace-with-a-long-random-secret

# 数据库连接
# 本地开发用 SQLite（默认，无需设置）：
# DATABASE_URI=file:./payload.db
#
# Railway PostgreSQL（Railway 会自动注入 DATABASE_URL）：
# DATABASE_URL=postgresql://...

# 站点公开 URL（Railway 部署后改为你的域名）
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
